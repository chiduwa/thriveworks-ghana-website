Options -Indexes
DirectoryIndex index.html

RewriteEngine On

# 1. Enforce HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# 2. www → non-www (canonical domain)
RewriteCond %{HTTP_HOST} ^www\.thriveworksghana\.org$ [NC]
RewriteRule ^ https://thriveworksghana.org%{REQUEST_URI} [R=301,L]

# 2.5. Redirect /index and /index.html to root
RewriteRule ^index(\.html)?/?$ / [R=301,L]

# 3. Redirect /page.html → /page (clean URLs, 301 permanent)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 4. Serve /page as /page.html transparently
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# 5. Block access to dotfiles (.git, .DS_Store, .env, .htaccess itself, etc.)
RewriteCond %{REQUEST_URI} /\.[^/]+$ [NC]
RewriteRule .* - [F,L]

# ── GZIP COMPRESSION ─────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE text/plain
</IfModule>

# ── BROWSER CACHING (Expires) ─────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — short cache so updates reach users quickly
  ExpiresByType text/html                  "access plus 1 hour"

  # CSS / JS — long cache (filenames change when content changes)
  ExpiresByType text/css                   "access plus 1 year"
  ExpiresByType application/javascript     "access plus 1 year"
  ExpiresByType text/javascript            "access plus 1 year"

  # Images — long cache
  ExpiresByType image/jpeg                 "access plus 1 year"
  ExpiresByType image/jpg                  "access plus 1 year"
  ExpiresByType image/png                  "access plus 1 year"
  ExpiresByType image/webp                 "access plus 1 year"
  ExpiresByType image/gif                  "access plus 1 year"
  ExpiresByType image/svg+xml              "access plus 1 year"
  ExpiresByType image/x-icon               "access plus 1 year"

  # Video — medium cache
  ExpiresByType video/mp4                  "access plus 1 month"
  ExpiresByType video/webm                 "access plus 1 month"

  # Fonts
  ExpiresByType font/woff                  "access plus 1 year"
  ExpiresByType font/woff2                 "access plus 1 year"
  ExpiresByType application/font-woff      "access plus 1 year"

  # Sitemap / XML
  ExpiresByType application/xml            "access plus 1 day"
  ExpiresByType text/xml                   "access plus 1 day"
</IfModule>

# ── CACHE-CONTROL HEADERS ─────────────────────────────────────────────────────
<IfModule mod_headers.c>
  <FilesMatch "\.(jpg|jpeg|png|gif|ico|svg|webp)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(mp4|webm)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
  <FilesMatch "sitemap\.xml$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>

  # Security headers
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  # frame-ancestors/object-src/base-uri only restrict embedding-by-others,
  # legacy plugin embeds, and base-tag injection — they don't touch what
  # this site itself loads, so they're safe to add without auditing every
  # GTM tag and third-party widget (Facebook, Google Forms, fonts) for a
  # full script-src/style-src policy, which would need live browser testing
  # this environment can't do against the production site.
  Header always set Content-Security-Policy "upgrade-insecure-requests; frame-ancestors 'self'; object-src 'none'; base-uri 'self'"

  # CORS for fonts
  <FilesMatch "\.(woff|woff2|ttf|otf|eot)$">
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
</IfModule>

# ── KEEP-ALIVE ────────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header set Connection keep-alive
</IfModule>
